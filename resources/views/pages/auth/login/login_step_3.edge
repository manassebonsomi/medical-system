<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Vérification du Code OTP 2FA</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css">
</head>
<body class="bg-gray-900">
  <div class="flex items-center justify-center min-h-screen">
    <div class="w-full max-w-md p-8 bg-black border border-gray-800 rounded-2xl">
      <h1 class="text-3xl font-bold text-white mb-2">Nous vous avons envoyé un code OTP pour votre authentification</h1>
      <p class="text-gray-400 mb-8 text-sm">
        Entrez le code OTP envoyé à
        <span class="text-white font-bold">{{ email }}</span>. Ce code expire dans 10 minutes. Étape 3 sur 3.
      </p>
      <form action="/login/e3" method="POST" class="space-y-6">
        {{ csrfField() }}

        <div>
          <label class="block text-sm text-gray-400">Code de vérification</label>
          <input type="text" name="code" maxlength="6" class="mt-1 w-full px-4 py-3 text-center tracking-[1em] text-2xl font-bold bg-transparent border {{ flashMessages.has('errors.code') ? 'border-red-500' : 'border-gray-700' }} rounded-md text-white outline-none focus:border-blue-500" placeholder="------">
        </div>
        @if(flashMessages.has('errors.code'))
          <div class="" style="color: red;">
            {{ flashMessages.get('errors.code') }}
          </div>
        @endif

        <button type="submit" class="w-full py-3 bg-white text-black font-bold rounded-full hover:bg-gray-200">Vérifier</button>
      </form>
    </div>
  </div>
</body>
</html>


