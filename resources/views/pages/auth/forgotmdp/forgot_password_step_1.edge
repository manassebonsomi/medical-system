<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Mdp 1</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css">
</head>
<body class="bg-gray-900">
<div class="flex items-center justify-center min-h-screen">
  <div class="w-full max-w-md p-8 bg-black border border-gray-800 rounded-2xl">
    <h1 class="text-3xl font-bold text-white mb-2">Retrouvez votre compte X</h1>
    <p class="text-gray-400 mb-8 text-sm">Entrez l'adresse email associée à votre compte pour modifier votre mot de passe.</p>

    <form action="{{ route('password.reset.step1') }}" method="POST" class="space-y-6">
      {{ csrfField() }}

      <div>
        <label class="block text-sm text-gray-400">Email</label>
        <input type="email" name="email" value="{{ old('email') || '' }}" autofocus class="mt-1 w-full px-4 py-3 bg-transparent border {{ flashMessages.has('errors.email') ? 'border-red-500' : 'border-gray-700' }} rounded-md text-white outline-none focus:border-blue-500">
        @if(flashMessages.has('error.email'))
        <div class="" style="color: red;">
          {{ flashMessages.get('error.email') }}
        </div>
        @endif
        @if(flashMessages.has('errors.email'))
           <div class="" style="color: red;">
               {{ flashMessages.get('errors.email') }}
            </div>
         @endif
      </div>

      <button type="submit" class="w-full py-3 bg-white text-black font-bold rounded-full hover:bg-gray-200">Rechercher</button>
    </form>
  </div>
</div>
</body>
</html>
