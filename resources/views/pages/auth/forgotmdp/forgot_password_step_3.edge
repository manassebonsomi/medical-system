<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Mdp 3</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css">
</head>
<body class="bg-gray-900">
<div class="flex items-center justify-center min-h-screen">
  <div class="w-full max-w-md p-8 bg-black border border-gray-800 rounded-2xl">
    <h1 class="text-3xl font-bold text-white mb-2">Choisissez un nouveau mot de passe</h1>
    <p class="text-gray-400 mb-8 text-sm">Assurez-vous qu'il contient au moins 8 caractères.</p>

    <form action="{{ route('password.reset.step3') }}" method="POST" class="space-y-6">
      {{ csrfField() }}

      <div>
        <label class="block text-sm text-gray-400">Nouveau mot de passe</label>
        <input type="password" name="password" autofocus class="mt-1 w-full px-4 py-3 bg-transparent border {{ flashMessages.has('errors.password') ? 'border-red-500' : 'border-gray-700' }} rounded-md text-white outline-none focus:border-blue-500">
        @if(flashMessages.has('error.password'))
        <div class="" style="color: red;">
          {{ flashMessages.get('error.password') }}
        </div>
        @endif
      </div>

      <button type="submit" class="w-full py-3 bg-blue-500 text-white font-bold rounded-full hover:bg-blue-600 transition">Réinitialiser le mot de passe</button>
      @if(flashMessages.has('error'))
        <div class="" style="color: red;">
          {{ flashMessages.get('error') }}
        </div>
        @endif
    </form>
  </div>
</div>
</body>
</html>
