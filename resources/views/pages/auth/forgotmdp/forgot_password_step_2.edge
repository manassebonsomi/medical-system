<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Forgot Mdp 1</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/tailwindcss@2.2.19/dist/tailwind.min.css">
</head>
<body class="bg-gray-900">
<div class="flex items-center justify-center min-h-screen">
  <div class="w-full max-w-md p-8 bg-black border border-gray-800 rounded-2xl">
    <h1 class="text-3xl font-bold text-white mb-2">Vérifiez votre identité</h1>
    <p class="text-gray-400 mb-8 text-sm">Un code de vérification a été envoyé à <span class="text-white font-bold">{{ email }}</span>.</p>

    <form action="{{ route('password.reset.step2') }}" method="POST" class="space-y-6">
      {{ csrfField() }}

      <div>
        <label class="block text-sm text-gray-400">Code de vérification</label>
        <input type="text" name="code" maxlength="6" autofocus class="mt-1 w-full px-4 py-3 text-center tracking-[1em] text-2xl font-bold bg-transparent border {{ flashMessages.has('errors.code') ? 'border-red-500' : 'border-gray-700' }} rounded-md text-white outline-none focus:border-blue-500" placeholder="------">
        @if(flashMessages.has('error.code'))
        <div class="" style="color: red;">
          {{ flashMessages.get('error.code') }}
        </div>
        @endif
        @if(flashMessages.has('errors.code'))
        <div class="" style="color: red;">
          {{ flashMessages.get('errors.code') }}
        </div>
        @endif
      </div>

      <button type="submit" class="w-full py-3 bg-white text-black font-bold rounded-full hover:bg-gray-200">Vérifier le code</button>
    </form>
  </div>
</div>
</body>
</html>
