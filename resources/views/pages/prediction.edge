<!-- MAIN WRAPPER -->
<div class="main-wrapper">

    <!-- PAGE CONTENT -->
    <div class="page-wrapper">

        <div class="content container-fluid">
            <!-- FORMULAIRE -->
            <div class="row">
                <div class="col-md-6 offset-md-3">

                    <div class="card">
                        <div class="card-body">

                            <form action="/predict" method="POST" enctype="multipart/form-data">
                                {{ csrfField() }}
                                <div class="page-header">
                        <div class="row">
                            <div class="col-sm-12">
                            <h3 class="text-center mb-4">Prédiction des images thoraciques</h3> 
                        </div>
                        </div>
                            </div>


                                <!-- IMAGE UPLOAD -->
                            <div class="form-group">
                                <label class="control-label">Importer une radiographie du thorax</label><div class="custom-file">
                                    <input type="file" class="custom-file-input" id="image" name="image" accept="image/*" required><label class="custom-file-label" for="image">Choisir une image thoracique</label>
                                </div>
                            </div>

                                <!-- TYPE MODELE -->
                                <div class="form-group">
                                    <label>Modèle IA</label>
                                    <select class="form-control" name="model">
                                        <option value="xception">Xception CNN</option>
                                        <option value="cnn">CNN Standard</option>
                                        <option value="transfer">Transfer Learning</option>
                                    </select>
                                </div>

                                <!-- BOUTON -->
                                <div class="form-group text-center">
                                    <button type="submit" class="btn btn-primary">
                                        Lancer la prédiction
                                    </button>
                                </div>
                                <div class="form-group text-center">
                                 <a href="resultats.html" class="btn btn-success">Voir les résultats des patients</a>
                                </div>

                            </form>

                            <!-- RESULTAT -->
                            <hr>

                            <div class="text-center">
                                <h5>Résultat de la prédiction</h5>

                                <div class="alert alert-info">
                                    <p><strong>Diagnostic :</strong> {{ prediction }}</p>
                                    <p><strong>Confiance :</strong> {{ accuracy }} %</p>
                                </div>
                            </div>

                        </div>
                    </div>

                </div>
            </div>

        </div>
    </div>

</div>
